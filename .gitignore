# O OS que o comprador gera nasce na RAIZ. É conteúdo dele, não versiona. Assim um
# git pull de melhoria do .genesis/ nunca conflita com o OS de quem já montou.
# Exceção: .claude/commands/ é do template (o comando /config-os), esse fica versionado.
/.claude/*
!/.claude/commands/
/contexto/
/producao/
/meu-os.json
/.genesis-atividade.jsonl

# python
__pycache__/
*.pyc
.venv/
.scratch/
